{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenCode",
  "version": "1.17.8",
  "identifier": "ai.opencode.desktop",
  "description": "AI-powered development tool - Tauri version",
  "authors": ["OpenCode Team"],
  "license": "MIT",
  "homepage": "https://opencode.ai",
  "repository": "https://github.com/anomalyco/opencode",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist",
    "backend": {
      "cargoFeatures": ["default"]
    }
  },
  "app": {
    "windows": [
      {
        "title": "OpenCode",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "visibleOnAllWorkspaces": false,
        "center": true,
        "theme": null,
        "defaultFont": null
      }
    ],
    "security": {
      "csp": null,
      "isolated": {
        "explicit": false
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "identifier": "ai.opencode.desktop",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBinaries": [],
    "macOS": {
      "entitlements": null,
      "hardenedRuntime": true,
      "gatekeeper": null,
      "notarization": null
    },
    "windows": {
      "certificate thumbprint": null,
      "digest algorithm": "sha256",
      "timestamp url": null
    },
    "linux": {
      "category": "Development",
      "executableName": "opencode"
    }
  },
  "plugins": {
    "shell": {
      "scripts": []
    },
    "dialog": {
      "scripts": []
    },
    "fs": {
      "scripts": []
    },
    "store": {
      "scripts": []
    },
    "notification": {
      "scripts": []
    },
    "clipboard": {
      "scripts": []
    }
  }
}
