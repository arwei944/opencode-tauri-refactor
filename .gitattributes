# OpenCode Tauri - 行尾与文件属性配置
# 仓库统一使用 LF，CRLF 仅为 Windows 平台特定文件保留

# 默认：所有文本文件使用 LF
*               text=auto eol=lf

# 显式指定源码为文本
*.rs            text eol=lf
*.ts            text eol=lf
*.tsx           text eol=lf
*.js            text eol=lf
*.jsx           text eol=js
*.json          text eol=lf
*.jsonc         text eol=lf
*.toml          text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
*.md            text eol=lf
*.css           text eol=lf
*.html          text eol=lf
*.lock          text eol=lf
*.gitignore     text eol=lf
*.gitattributes text eol=lf

# Shell 脚本统一 LF
*.sh            text eol=lf

# Windows 平台脚本/项目文件用 CRLF
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

# 二进制资源
*.png           binary
*.ico           binary
*.icns          binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.webp          binary
*.woff          binary
*.woff2         binary
*.ttf           binary
*.otf           binary
*.eot           binary
